{
  "name": "cucumber-express",
  "version": "0.1.0",
  "description": "Cucumber-js helper for validating response objects via Gherkin data tables",
  "type": "module",
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "example:assertions": "npm start --prefix examples/assertions",
    "example:building": "npm start --prefix examples/building",
    "example:schemas": "npm start --prefix examples/schemas",
    "example:full-flow": "npm start --prefix examples/full-flow",
    "example:errors": "npm start --prefix examples/errors"
  },
  "peerDependencies": {
    "@cucumber/cucumber": ">=9.0.0",
    "@faker-js/faker": ">=8.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@faker-js/faker": "^9.0.0",
    "@types/node": "^25.9.1",
    "typescript": "^5.0.0",
    "tsx": "^4.0.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
